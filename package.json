{
  "name": "easctl",
  "version": "0.1.0",
  "description": "CLI tool for the Ethereum Attestation Service — create, revoke, and query attestations from the command line",
  "bin": {
    "easctl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "ethereum",
    "attestation",
    "eas",
    "cli",
    "ethers",
    "web3"
  ],
  "author": "Ethereum Attestation Service",
  "license": "MIT",
  "dependencies": {
    "@ethereum-attestation-service/eas-sdk": "^2.9.0",
    "commander": "^13.1.0",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
